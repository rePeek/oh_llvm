diff --git a/llvm-build/build.py b/llvm-build/build.py
index c1ab74666fbe..250eec034cc3 100755
--- a/llvm-build/build.py
+++ b/llvm-build/build.py
@@ -51,6 +51,12 @@ class BuildConfig():
         self.target_debug = args.target_debug
         self.strip = args.strip
         self.no_lto = args.no_lto
+        self.parallel_link_jobs = args.parallel_link_jobs
+        self.thinlto_jobs = args.thinlto_jobs
+        if self.parallel_link_jobs is not None and self.parallel_link_jobs < 1:
+            raise ValueError('--parallel-link-jobs must be greater than zero')
+        if self.thinlto_jobs is not None and self.thinlto_jobs < 1:
+            raise ValueError('--thinlto-jobs must be greater than zero')
         self.build_instrumented = args.build_instrumented
         self.xunit_xml_output = args.xunit_xml_output
         self.enable_assertions = args.enable_assertions
@@ -223,6 +229,18 @@ class BuildConfig():
             default=False,
             help='Accelerate builds by disabling LTO (only affects llvm product)')
 
+        parser.add_argument(
+            '--parallel-link-jobs',
+            type=int,
+            default=None,
+            help='Maximum number of concurrent LLVM link jobs')
+
+        parser.add_argument(
+            '--thinlto-jobs',
+            type=int,
+            default=None,
+            help='Maximum number of threads used by each ThinLTO link job')
+
         parser.add_argument(
             '--build-instrumented',
             action='store_true',
@@ -925,6 +943,9 @@ class LlvmCore(BuildUtils):
             if not build_instrumented and not no_lto and not debug_build:
                 llvm_defines['LLVM_ENABLE_LTO'] = 'Thin'
 
+            if self.build_config.parallel_link_jobs:
+                llvm_defines['LLVM_PARALLEL_LINK_JOBS'] = str(self.build_config.parallel_link_jobs)
+
             if self.build_config.build_libxml2:
                 llvm_defines['LIBXML2_LIBRARY'] = \
                     self.merge_libxml2_install_dir(self.use_platform(), 'lib', f'libxml2.so.{self.build_config.LIBXML2_VERSION}')
@@ -1054,6 +1075,9 @@ class LlvmCore(BuildUtils):
             if not self.host_is_linux_aarch64():
                 ldflags += ' -l:libunwind.a -l:libc++abi.a --rtlib=compiler-rt -stdlib=libc++'
             ldflags += ' -static-libstdc++'
+            if self.build_config.thinlto_jobs and not no_lto and not debug_build and not build_instrumented:
+                ldflags += ' -Wl,--threads={0} -Wl,--thinlto-jobs={0}'.format(
+                    self.build_config.thinlto_jobs)
 
         if xunit_xml_output:
             llvm_defines['LLVM_LIT_ARGS'] = "--xunit-xml-output={} -sv".format(xunit_xml_output)
